# pc-judge configuration (runs on the PC).
# Ollama endpoint on THIS machine.
OLLAMA_URL=http://127.0.0.1:11434
# Text model to judge with (pull it first: `ollama pull qwen2.5:7b-instruct`).
JUDGE_MODEL=qwen2.5:7b-instruct
# Bind 0.0.0.0 so the Mac can reach this over the LAN.
JUDGE_HOST=0.0.0.0
JUDGE_PORT=8100
# Local models can be slow; give generous timeout (seconds).
JUDGE_TIMEOUT=120
# Set to 1 to log raw model output.
DEBUG=0
