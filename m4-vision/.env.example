# m4-vision configuration (runs on the Mac).

# Local VLM via Ollama on THIS machine (perception).
OLLAMA_URL=http://127.0.0.1:11434
# Pull it first, e.g. `ollama pull moondream` or `ollama pull minicpm-v`.
VLM_MODEL=moondream

# The pc-judge service. Use the PC's LAN IP once you deploy it there;
# 127.0.0.1 works if you run pc-judge on this same machine for testing.
JUDGE_SERVICE_URL=http://127.0.0.1:8100

# Capture / cadence
CAPTURE_INTERVAL=2.0
VISION_INTERVAL=6.0
VISION_BATCH_SIZE=3

# Timeouts (seconds) — local models can be slow.
VLM_TIMEOUT=120
JUDGE_TIMEOUT=120

# Set to 1 to log raw model output.
DEBUG=0
