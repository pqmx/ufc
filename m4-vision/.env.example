# m4-vision configuration (runs on the Mac).

# Local VLM via Ollama on THIS machine (perception).
OLLAMA_URL=http://127.0.0.1:11434
# Pull it first: `ollama pull qwen2.5vl:3b`.
VLM_MODEL=qwen2.5vl:3b
# Keep the model hot for a full fight so it never cold-reloads mid-round.
OLLAMA_KEEP_ALIVE=30m

# The pc-judge service. Use the PC's LAN IP, e.g. http://192.168.1.50:8100.
# Use 127.0.0.1 only if you run pc-judge on this same Mac for testing.
JUDGE_SERVICE_URL=http://127.0.0.1:8100

# Capture / cadence
CAPTURE_INTERVAL=2.0
VISION_INTERVAL=6.0
VISION_BATCH_SIZE=2

# Bound context/output for steady latency across a long fight.
VLM_NUM_CTX=4096
VLM_NUM_PREDICT=512

# Timeouts (seconds) — local models can be slow.
VLM_TIMEOUT=120
JUDGE_TIMEOUT=120

# Set to 1 to log raw model output.
DEBUG=0
